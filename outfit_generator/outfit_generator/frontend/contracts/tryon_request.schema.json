{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TryOnRequest",
  "type": "object",
  "required": ["garment_size"],
  "properties": {
    "model_url": { "type": "string" },
    "clothing_url": { "type": "string" },
    "garment_size": {
      "type": "string",
      "enum": ["XXXS", "XXS", "XS", "S", "M", "L", "XL", "XXL", "XXXL", "ONE SIZE"]
    },
    "body_measurements": { "type": "object" },
    "pose": { "type": "string" },
    "background": { "type": "string" },
    "aspect_ratio": {
      "type": "string",
      "enum": ["1:1", "3:4", "4:5", "2:3", "9:16", "16:9"]
    }
  },
  "additionalProperties": true
}
