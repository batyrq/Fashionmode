{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TryOnResponse",
  "type": "object",
  "required": ["success", "message"],
  "properties": {
    "success": { "type": "boolean" },
    "message": { "type": "string" },
    "task_id": { "type": ["integer", "null"] },
    "result_url": { "type": ["string", "null"] },
    "output_images": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source": { "type": "object" },
    "clip_analysis": { "type": "object" },
    "claid_prompt": { "type": "object" },
    "fit_analysis": { "type": "object" },
    "fit_warning": { "type": ["string", "null"] },
    "raw_result": { "type": ["object", "null"] }
  },
  "additionalProperties": true
}
